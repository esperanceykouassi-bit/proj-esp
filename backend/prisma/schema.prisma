generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CategorieFormation {
  SAARI
  BUREAUTIQUE
  LEADERSHIP
  COMPTABLE
  PROJET
}

enum StatutFormation {
  ACTIF
  INACTIF
}

enum StatutInscription {
  EN_ATTENTE
  CONFIRMEE
  ANNULEE
}

// ─── Modèles ──────────────────────────────────────────────────────────────────

model Formation {
  id          Int                 @id @default(autoincrement())
  titre       String
  categorie   CategorieFormation
  description String
  duree       String              // ex: "3 jours", "16 heures"
  prix        Int                 // en XOF (FCFA)
  statut      StatutFormation     @default(ACTIF)
  createdAt   DateTime            @default(now())

  inscriptions Inscription[]

  @@map("formations")
}

model Inscription {
  id          Int               @id @default(autoincrement())
  nom         String
  prenom      String
  email       String
  telephone   String
  formationId Int
  message     String?
  statut      StatutInscription @default(EN_ATTENTE)
  createdAt   DateTime          @default(now())

  formation Formation @relation(fields: [formationId], references: [id])

  @@map("inscriptions")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  nom       String
  email     String
  telephone String?
  sujet     String?
  message   String
  lu        Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}
